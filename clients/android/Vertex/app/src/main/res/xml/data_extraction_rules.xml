<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- We do not allow backup/transfer of any app data:
         identity key (TOFU-bound) and credentials are hardware-bound to this device. -->
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
