<?xml version="1.0" encoding="utf-8"?>
<!-- Notification status-bar icon. Must be a single white silhouette per Material guidelines:
     coloured/multi-tone notification icons are tinted to plain white by the system on API 21+.
     Same V-asterisk shape as the launcher icon, simplified for 24×24 viewport. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="@android:color/white">

    <!-- Six rays from (12,12), length 8, stroke 1.5 -->
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,12 L12,4" />
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,12 L12,20" />
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,12 L18.93,8" />
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,12 L5.07,16" />
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,12 L18.93,16" />
    <path
        android:strokeColor="@android:color/white"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:pathData="M12,12 L5.07,8" />

    <!-- Center node -->
    <path
        android:fillColor="@android:color/white"
        android:pathData="M12,12 m-1.6,0 a1.6,1.6 0 1,1 3.2,0 a1.6,1.6 0 1,1 -3.2,0" />
</vector>
