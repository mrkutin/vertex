<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Vertex.App.Controls.StatusPill"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Capsule pill: MinHeight = 32, CornerRadius = 16 = MinHeight / 2.
        Don't use 999 — WinUI flattens oversized radii into ellipses.
    -->
    <Border x:Name="Capsule"
            Background="{StaticResource BgSurfaceElevBrush}"
            BorderBrush="{StaticResource BorderSubtleBrush}"
            BorderThickness="0.5"
            CornerRadius="16"
            MinHeight="32"
            Padding="14,0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
            <Grid Width="14" Height="14" VerticalAlignment="Center">
                <Ellipse x:Name="Glow"
                         Width="14" Height="14"
                         Fill="{StaticResource StateConnectedBrush}"
                         Opacity="0"/>
                <Ellipse x:Name="Dot"
                         Width="6" Height="6"
                         Fill="{StaticResource StateDormantBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="Label"
                       Text="Not connected"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="13"
                       FontFamily="Consolas"
                       VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
