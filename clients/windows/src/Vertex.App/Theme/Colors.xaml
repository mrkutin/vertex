<?xml version="1.0" encoding="utf-8"?>
<!--
    Vertex dark palette. Hex values mirror the dark variants of
    clients/macos/Vertex/App/Assets.xcassets/*.colorset/Contents.json so
    the four-platform UI reads visually identical. Don't drift these by
    eye — convert the macOS RGB[0,1] components straight to hex.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="BgCanvas">#FF080F26</Color>
    <Color x:Key="BgSurface">#FF101A3D</Color>
    <Color x:Key="BgSurfaceElev">#FF162456</Color>
    <Color x:Key="BgSurfaceMuted">#FF0C1430</Color>
    <!-- 8 % white — same alpha trick as macOS borderSubtle dark. -->
    <Color x:Key="BorderSubtle">#14FFFFFF</Color>

    <!-- Accents -->
    <Color x:Key="AccentPrimary">#FF7DB3FF</Color>
    <!-- 18 % alpha over the same base as AccentPrimary. -->
    <Color x:Key="AccentPrimaryMuted">#2E7DB3FF</Color>
    <!-- 60 % alpha — only used inside RadialGradientBrush stops. -->
    <Color x:Key="GlowPrimary">#997DB3FF</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#FFFFFFFF</Color>
    <Color x:Key="TextSecondary">#C7C4D2EE</Color>
    <Color x:Key="TextTertiary">#998497C2</Color>
    <Color x:Key="GlyphDim">#80C4D2EE</Color>

    <!-- Status -->
    <Color x:Key="StateConnected">#FF7DB3FF</Color>
    <Color x:Key="StateTransitioning">#FFFAD27A</Color>
    <Color x:Key="StateError">#FFFF6E78</Color>
    <Color x:Key="StateDormant">#FF8497C2</Color>

    <!-- SolidColorBrush wrappers for convenience binding. -->
    <SolidColorBrush x:Key="BgCanvasBrush"           Color="{StaticResource BgCanvas}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush"          Color="{StaticResource BgSurface}"/>
    <SolidColorBrush x:Key="BgSurfaceElevBrush"      Color="{StaticResource BgSurfaceElev}"/>
    <SolidColorBrush x:Key="BgSurfaceMutedBrush"     Color="{StaticResource BgSurfaceMuted}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush"       Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="AccentPrimaryBrush"      Color="{StaticResource AccentPrimary}"/>
    <SolidColorBrush x:Key="AccentPrimaryMutedBrush" Color="{StaticResource AccentPrimaryMuted}"/>
    <SolidColorBrush x:Key="GlowPrimaryBrush"        Color="{StaticResource GlowPrimary}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"        Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"      Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextTertiaryBrush"       Color="{StaticResource TextTertiary}"/>
    <SolidColorBrush x:Key="GlyphDimBrush"           Color="{StaticResource GlyphDim}"/>
    <SolidColorBrush x:Key="StateConnectedBrush"     Color="{StaticResource StateConnected}"/>
    <SolidColorBrush x:Key="StateTransitioningBrush" Color="{StaticResource StateTransitioning}"/>
    <SolidColorBrush x:Key="StateErrorBrush"         Color="{StaticResource StateError}"/>
    <SolidColorBrush x:Key="StateDormantBrush"       Color="{StaticResource StateDormant}"/>
</ResourceDictionary>
