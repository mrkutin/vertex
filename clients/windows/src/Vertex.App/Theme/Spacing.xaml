<?xml version="1.0" encoding="utf-8"?>
<!--
    Vertex spacing scale (4-pt grid) and corner-radius scale.
    Mirror of macOS VxSpace / VxRadius — see design/UI-SPEC.md §3.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Spacing scale -->
    <x:Double x:Key="Vx_s0">0</x:Double>
    <x:Double x:Key="Vx_s1">4</x:Double>
    <x:Double x:Key="Vx_s2">8</x:Double>
    <x:Double x:Key="Vx_s3">12</x:Double>
    <x:Double x:Key="Vx_s4">16</x:Double>
    <x:Double x:Key="Vx_s5">20</x:Double>
    <x:Double x:Key="Vx_s6">24</x:Double>
    <x:Double x:Key="Vx_s7">28</x:Double>
    <x:Double x:Key="Vx_s8">32</x:Double>
    <x:Double x:Key="Vx_s10">40</x:Double>
    <x:Double x:Key="Vx_s12">48</x:Double>

    <!-- Corner radii -->
    <CornerRadius x:Key="Vx_r_sm">8</CornerRadius>
    <CornerRadius x:Key="Vx_r_md">12</CornerRadius>
    <CornerRadius x:Key="Vx_r_lg">16</CornerRadius>
    <CornerRadius x:Key="Vx_r_xl">22</CornerRadius>
    <CornerRadius x:Key="Vx_r_capsule">999</CornerRadius>

    <!-- Convenience Thicknesses (Padding/Margin literals) -->
    <Thickness x:Key="Vx_screen_padding">20,8,20,32</Thickness>
</ResourceDictionary>
