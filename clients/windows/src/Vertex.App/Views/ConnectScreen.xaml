<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Vertex.App.Views.ConnectScreen"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vertex.App.Controls">

    <Grid Background="{StaticResource BgCanvasBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Spacing="28"
                        MaxWidth="480"
                        Padding="20,8,20,32"
                        HorizontalAlignment="Stretch">

                <!-- Wordmark + Settings gear -->
                <Grid>
                    <TextBlock Text="VERTEX"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               CharacterSpacing="100"
                               HorizontalAlignment="Center"/>
                    <Button x:Name="SettingsButton"
                            Click="OnSettingsClick"
                            HorizontalAlignment="Right"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xE713;"
                                  FontSize="18"
                                  Foreground="{StaticResource AccentPrimaryBrush}"/>
                    </Button>
                </Grid>

                <!-- Hero + status text + pill + speed -->
                <StackPanel Spacing="10" HorizontalAlignment="Center">
                    <controls:VertexHero x:Name="Hero" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="StatusText"
                               Text="Disconnected"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="22"
                               FontWeight="SemiBold"
                               CharacterSpacing="-20"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                    <controls:StatusPill x:Name="Pill" HorizontalAlignment="Center"/>
                    <controls:SpeedPill x:Name="Speed" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- ServerCard -->
                <controls:ServerCard x:Name="ServerCardView"
                                     BrokerTapped="OnBrokerTapped"
                                     ExitTapped="OnExitTapped"/>

                <!-- BigConnectButton -->
                <controls:BigConnectButton x:Name="ConnectButton" Activated="OnConnectTapped"/>

                <!-- Error banner -->
                <Border x:Name="ErrorBanner"
                        Visibility="Collapsed"
                        Background="#1FFF6E78"
                        BorderBrush="#59FF6E78"
                        BorderThickness="0.5"
                        CornerRadius="{StaticResource Vx_r_lg}"
                        Padding="12">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE7BA;"
                                  FontSize="16"
                                  Foreground="{StaticResource StateErrorBrush}"
                                  VerticalAlignment="Top"/>
                        <TextBlock x:Name="ErrorText"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   MaxWidth="400"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
