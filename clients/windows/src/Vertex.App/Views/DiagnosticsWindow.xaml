<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Vertex.App.Views.DiagnosticsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Vertex.App.Controls"
    Title="Vertex Connection">

    <Grid Background="{StaticResource BgCanvasBrush}" RequestedTheme="Dark">
        <ScrollViewer>
            <StackPanel Spacing="20" Padding="24">

                <!-- Hero — small marquee at the top so the diagnostic page reads as a sibling of the main screen. -->
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <controls:VertexHero x:Name="Hero"
                                         Width="120" Height="120"
                                         HorizontalAlignment="Center"/>
                    <TextBlock x:Name="StatusLine"
                               Text="Disconnected"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Vertex section — assigned IP, broker, exit, connected time -->
                <StackPanel Spacing="6">
                    <TextBlock Text="VERTEX"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               FontSize="11"
                               CharacterSpacing="80"/>
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0.5"
                            CornerRadius="{StaticResource Vx_r_lg}"
                            Padding="16">
                        <StackPanel x:Name="VertexRowsHost" Spacing="12"/>
                    </Border>
                </StackPanel>

                <!-- Traffic section — bytes up/down + packets -->
                <StackPanel Spacing="6">
                    <TextBlock Text="TRAFFIC"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               FontSize="11"
                               CharacterSpacing="80"/>
                    <Border Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="0.5"
                            CornerRadius="{StaticResource Vx_r_lg}"
                            Padding="16">
                        <StackPanel x:Name="TrafficRowsHost" Spacing="12"/>
                    </Border>
                </StackPanel>

                <!-- Export Diagnostics + Done -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                    <Button x:Name="ExportButton"
                            Content="Export…"
                            Click="OnExportClick"
                            Foreground="{StaticResource AccentPrimaryBrush}"
                            Background="Transparent"
                            BorderThickness="0"/>
                    <Button Content="Done"
                            Click="OnDoneClick"
                            Foreground="{StaticResource AccentPrimaryBrush}"
                            Background="Transparent"
                            BorderThickness="0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
