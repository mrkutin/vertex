<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="Vertex.App.Views.ExitListDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Edges"
    PrimaryButtonText="Refresh"
    CloseButtonText="Close"
    DefaultButton="Close"
    RequestedTheme="Dark"
    Background="{StaticResource BgSurfaceBrush}"
    Foreground="{StaticResource TextPrimaryBrush}"
    BorderBrush="{StaticResource BorderSubtleBrush}"
    BorderThickness="0.5"
    CornerRadius="{StaticResource Vx_r_lg}"
    PrimaryButtonClick="OnRefreshClick"
    CloseButtonClick="OnCloseClick">

    <Grid MinWidth="380" MaxWidth="440">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Available Edges"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="13"
                   Margin="4,0,0,8"/>

        <ScrollViewer Grid.Row="1" MaxHeight="420" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="RowsHost" Spacing="0"/>
        </ScrollViewer>

        <TextBlock Grid.Row="2"
                   Text="The edge is the network shoulder where your traffic exits to the public internet."
                   Foreground="{StaticResource TextTertiaryBrush}"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="4,12,0,0"/>
    </Grid>
</ContentDialog>
