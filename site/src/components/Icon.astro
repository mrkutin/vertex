---
/**
 * Inline Lucide-style icon. Strokes use currentColor so the parent's text
 * color drives the visual. Path data is embedded statically — no runtime fetch
 * and no external SVG sprite, so the build remains a pure static site.
 *
 * Adding an icon: extend the ICON_PATHS map in `icons.ts` (kept separate so
 * Astro's frontmatter parser doesn't trip over the union type).
 */
import { ICON_PATHS, type IconName } from './icons';
export type { IconName };

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  class?: string;
  title?: string;
  ariaHidden?: boolean;
}

const {
  name,
  size = 20,
  strokeWidth = 1.75,
  class: className,
  title,
  ariaHidden = true,
} = Astro.props;

const inner = ICON_PATHS[name];
const accessible = title && !ariaHidden;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class:list={['vx-icon', className]}
  role={accessible ? 'img' : undefined}
  aria-hidden={ariaHidden ? 'true' : undefined}
  aria-label={accessible ? title : undefined}
  focusable="false"
  set:html={inner}
/>

<style>
  .vx-icon {
    flex-shrink: 0;
    display: inline-block;
    vertical-align: middle;
  }
</style>
