# Docker test ACL — uses wildcard vpn/+/ for convenience.
# Production ACL should be exit-specific (generated by vtx-admin add -exits=aws,ams).
# Wildcard allows clients to access any exit, which is a DoS vector in production.

# Exit AWS (Canada)
user vtx-exit-mtl
topic read vpn/mtl/+/out
topic write vpn/mtl/+/in
topic read vpn/mtl/control/join
topic write vpn/mtl/+/control
topic write discovery/exits/mtl
topic write discovery/ping/mtl/+

# Exit AMS (Netherlands)
user vtx-exit-ams
topic read vpn/ams/+/out
topic write vpn/ams/+/in
topic read vpn/ams/control/join
topic write vpn/ams/+/control
topic write discovery/exits/ams
topic write discovery/ping/ams/+

# Client R3S — can use any exit
user vtx-client-r3s
topic write vpn/+/r3s/out
topic read vpn/+/r3s/in
topic read vpn/+/r3s/control
topic write vpn/+/control/join
topic read discovery/exits/+

# Client Mac — can use any exit
user vtx-client-mac
topic write vpn/+/mac/out
topic read vpn/+/mac/in
topic read vpn/+/mac/control
topic write vpn/+/control/join
topic read discovery/exits/+

# Client Auto — can use any exit (auto-select test)
user vtx-client-auto
topic write vpn/+/auto/out
topic read vpn/+/auto/in
topic read vpn/+/auto/control
topic write vpn/+/control/join
topic read discovery/exits/+

# Client WSS — can use any exit (WSS fallback test)
user vtx-client-wss
topic write vpn/+/wss/out
topic read vpn/+/wss/in
topic read vpn/+/wss/control
topic write vpn/+/control/join
topic read discovery/exits/+
